# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: override LLM provider ───────────────────────────────────────────

# Provider: anthropic (default) | openai | ollama
# LLM_PROVIDER=anthropic

# API key for non-Anthropic providers
# LLM_API_KEY=...

# Base URL for OpenAI-compatible APIs or Ollama
# LLM_BASE_URL=http://localhost:11434

# Override the model for each tier
# LLM_MODEL_SMART=claude-sonnet-4-20250514
# LLM_MODEL_CHEAP=claude-haiku-4-5-20251001

# ── Optional: paths and ports ─────────────────────────────────────────────────

# Path to your brands directory
# BRANDS_DIR=./brands

# Frame server port
# PORT=3001
